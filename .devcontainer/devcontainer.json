{
	"$schema": "https://raw.githubusercontent.com/devcontainers/spec/refs/heads/main/schemas/devContainer.base.schema.json",
	"name": "directus-extensions",
	"image": "mcr.microsoft.com/vscode/devcontainers/base:ubuntu-24.04",
	"features": {
		"ghcr.io/devcontainers-extra/features/mise:1": {
			"version": "latest"
		}
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"christian-kohler.npm-intellisense",
				"davidanson.vscode-markdownlint",
				"dbaeumer.vscode-eslint",
				"editorconfig.editorconfig",
				"esbenp.prettier-vscode",
				"github.copilot",
				"github.vscode-github-actions",
				"github.vscode-pull-request-github",
				"hverlin.mise-vscode",
				"tamasfe.even-better-toml",
				"vercel.turbo-vsc"
			]
		}
	},
	"mounts": [
		{
			"source": "vscode-local-data",
			"target": "/home/vscode/.local",
			"type": "volume"
		}
	],
	"containerEnv": {
		"MISE_TRUSTED_CONFIG_PATHS": "${containerWorkspaceFolder}"
	},
	"remoteEnv": {
		"MISE_EXPERIMENTAL": "true",
		"MISE_LOCKFILE": "true"
	},
	"onCreateCommand": ".devcontainer/hooks/on-create.sh",
	"postCreateCommand": ".devcontainer/hooks/post-create.sh"
}
